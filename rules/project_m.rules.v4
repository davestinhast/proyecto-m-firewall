# Hotmail / Outlook: set PM_HOTMAIL (48 IPs cargadas)
-A PM_WEBBLOCK -p tcp --dport 80 -m set --match-set PM_HOTMAIL dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 80 -m set --match-set PM_HOTMAIL dst -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m set --match-set PM_HOTMAIL dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 443 -m set --match-set PM_HOTMAIL dst -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "hotmail.com" --algo bm --to 65535 -j PM_REJECT
