# [Reglas de Bloqueo DNS Agresivo (Filtro de Contenido)]
-A PM_WEBBLOCK -p tcp -d 1.1.1.1 --dport 443 -j PM_REJECT
-A PM_WEBBLOCK -p tcp -d 1.0.0.1 --dport 443 -j PM_REJECT
-A PM_WEBBLOCK -p tcp -d 8.8.8.8 --dport 443 -j PM_REJECT
-A PM_WEBBLOCK -p tcp -d 8.8.4.4 --dport 443 -j PM_REJECT
-A PM_WEBBLOCK -p tcp -d 9.9.9.9 --dport 443 -j PM_REJECT
# Bloqueo global de DoT (puerto 853) para forzar fallback a DNS normal
-A PM_WEBBLOCK -p tcp --dport 853 -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 853 -j PM_REJECT
# Bloqueo global de QUIC para forzar fallback a TCP
