# M-FIREWALL v1.0.0 — Archivo de reglas PERSONALIZADO
# Generado: 2026-07-18 22:55:14
# Guardado en: /opt/proyecto-m/rules/project_m.rules.v4
# (NO se usa /etc/sysconfig/iptables — rúbrica requiere archivo personalizado)
# Cargar con: iptables-restore < project_m.rules.v4
# IPs bloqueadas via ipset: ipset restore < project_m.ipset

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
-A PREROUTING -p udp --dport 53 -j DNAT --to-destination 192.168.50.1:10053
-A PREROUTING -p tcp --dport 53 -j DNAT --to-destination 192.168.50.1:10053
-A OUTPUT -p udp --dport 53 -m owner ! --uid-owner 0 -j DNAT --to-destination 127.0.0.1:10053
-A OUTPUT -p tcp --dport 53 -m owner ! --uid-owner 0 -j DNAT --to-destination 127.0.0.1:10053
-A POSTROUTING -o eth0 -j MASQUERADE
COMMIT

*filter
:PM_WEBBLOCK - [0:0]
:PM_MACBLOCK - [0:0]
:PM_CONNLIMIT - [0:0]
:PM_CLISRV - [0:0]
:PM_DNSBLOCK - [0:0]
:PM_REJECT - [0:0]
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

# [Cadena PM_REJECT: registra y rechaza]
-A PM_REJECT -m limit --limit 5/min --limit-burst 10 -j LOG --log-prefix "PM-DROP " --log-level 4
-A PM_REJECT -j DROP

# [Cadena PM_MACBLOCK: bloqueo por MAC]
# MAC: Client1
-A PM_MACBLOCK -i eth1 -m mac --mac-source 00:11:22:33:44:55 -j PM_REJECT

# [Cadena PM_CONNLIMIT: límite de conexiones simultáneas]
# connlimit: SSH (max 3 conexiones en puerto 22/tcp)
-A PM_CONNLIMIT -p tcp --dport 22 -m connlimit --connlimit-above 3 --connlimit-mask 32 -j REJECT --reject-with tcp-reset
# connlimit: HTTP (max 10 conexiones en puerto 80/tcp)
-A PM_CONNLIMIT -p tcp --dport 80 -m connlimit --connlimit-above 10 --connlimit-mask 32 -j REJECT --reject-with tcp-reset
# connlimit: HTTPS (max 10 conexiones en puerto 443/tcp)
-A PM_CONNLIMIT -p tcp --dport 443 -m connlimit --connlimit-above 10 --connlimit-mask 32 -j REJECT --reject-with tcp-reset

# [Cadena PM_CLISRV: bloqueo cliente-servidor]
-A PM_CLISRV -i eth1 -s 192.168.50.10 -d 192.168.50.1 -m state --state ESTABLISHED,RELATED -j ACCEPT
-A PM_CLISRV -i eth1 -p tcp -s 192.168.50.10 -d 192.168.50.1 -m state --state NEW -j PM_REJECT
-A PM_CLISRV -i eth1 -p udp -s 192.168.50.10 -d 192.168.50.1 -m state --state NEW -j PM_REJECT
-A PM_CLISRV -i eth1 -p icmp -s 192.168.50.10 -d 192.168.50.1 -m state --state NEW -j PM_REJECT

# [Cadena PM_WEBBLOCK: bloqueo por ipset]
# Los sets PM_FACEBOOK, PM_YOUTUBE, PM_HOTMAIL se cargan con:
# ipset restore < /opt/proyecto-m/rules/project_m.ipset

# Facebook: set PM_FACEBOOK (5 IPs cargadas)
-A PM_WEBBLOCK -p tcp --dport 80 -m set --match-set PM_FACEBOOK dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 80 -m set --match-set PM_FACEBOOK dst -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m set --match-set PM_FACEBOOK dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 443 -m set --match-set PM_FACEBOOK dst -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "facebook.com" --algo bm --to 65535 -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "fbcdn.net" --algo bm --to 65535 -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "fb.com" --algo bm --to 65535 -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "messenger.com" --algo bm --to 65535 -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m string --string "fbsbx.com" --algo bm --to 65535 -j PM_REJECT
# YouTube: set PM_YOUTUBE (141 IPs cargadas)
-A PM_WEBBLOCK -p tcp --dport 80 -m set --match-set PM_YOUTUBE dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 80 -m set --match-set PM_YOUTUBE dst -j PM_REJECT
-A PM_WEBBLOCK -p tcp --dport 443 -m set --match-set PM_YOUTUBE dst -j PM_REJECT
-A PM_WEBBLOCK -p udp --dport 443 -m set --match-set PM_YOUTUBE dst -j PM_REJECT
