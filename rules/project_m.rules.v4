# [Saltos INPUT a cadenas personalizadas]
-A INPUT -p udp --dport 10053 -j ACCEPT
-A INPUT -p tcp --dport 10053 -j ACCEPT
-A INPUT -j PM_WEBBLOCK
-A INPUT -p udp --dport 53 -j PM_DNSBLOCK
-A INPUT -p tcp --dport 53 -j PM_DNSBLOCK

# [Saltos FORWARD a cadenas personalizadas]
-A FORWARD -i eth1 -j PM_MACBLOCK
-A FORWARD -i eth1 -j PM_CONNLIMIT
-A FORWARD -i eth1 -j PM_CLISRV
-A FORWARD -i eth1 -j PM_WEBBLOCK
-A FORWARD -p udp --dport 53 -j PM_DNSBLOCK
-A FORWARD -p tcp --dport 53 -j PM_DNSBLOCK

# [Saltos OUTPUT a PM_WEBBLOCK para bloqueo local]
-A OUTPUT -j PM_WEBBLOCK
-A OUTPUT -p udp --dport 53 -m owner ! --uid-owner 0 -j PM_DNSBLOCK
-A OUTPUT -p tcp --dport 53 -m owner ! --uid-owner 0 -j PM_DNSBLOCK

COMMIT
